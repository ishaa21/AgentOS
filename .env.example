# ─────────────────────────────────────────────
# AgentOS — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values

# ── Google Gemini API Key (REQUIRED for AI features) ──
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ── Database (optional — defaults to bundled SQLite for local dev) ──
# For PostgreSQL / AlloyDB in production:
#   DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/agentos
# For AlloyDB via Auth Proxy (localhost):
#   DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@127.0.0.1:5432/agentos
#
# Leave unset to use the bundled SQLite file (agentOS.db) — works out of the box.
# DATABASE_URL=

# ── Server Port (Cloud Run sets this automatically) ──
PORT=8000
